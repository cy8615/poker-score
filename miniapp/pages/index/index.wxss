.container { padding: 40rpx 24rpx; }

/* 微信头像昵称 */
.profile-bar { display: flex; flex-direction: row; align-items: center; padding: 0 4rpx 18rpx; }
.prof-avatar { width: 72rpx; height: 72rpx; border-radius: 50%; flex-shrink: 0; }
.prof-avatar-placeholder { font-size: 40rpx; opacity: 0.5; }
.prof-avatar-text { width: 72rpx; height: 72rpx; border-radius: 50%; background: var(--surface); border: 2rpx solid var(--border); display: flex; align-items: center; justify-content: center; font-size: 32rpx; font-weight: 600; color: var(--text); flex-shrink: 0; }
.prof-nickname { flex: 1; margin-left: 20rpx; font-size: 32rpx; font-weight: 600; color: var(--text); }
.prof-nickname-dim { color: var(--text3); font-weight: 400; }
.avatar-picker { width: 72rpx; height: 72rpx; padding: 0; margin: 0; border-radius: 50%; overflow: hidden; background: var(--surface); border: 2rpx solid var(--border); line-height: 1; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.avatar-picker::after { border: none; }
.hero { text-align: center; padding: 40rpx 0 20rpx; }
.hero-icon { font-size: 88rpx; }
.hero-title { display: block; font-size: 48rpx; font-weight: 700; margin: 12rpx 0 4rpx; color: var(--text); }
.hero-sub { font-size: 28rpx; color: var(--text3); }

.actions { display: flex; flex-direction: row; margin: 24rpx 0; }
.action-card { flex: 1; background: var(--surface); border-radius: 16rpx; padding: 28rpx 20rpx; text-align: center; margin: 0 8rpx; }
.action-card:first-child { margin-left: 0; }
.action-card:last-child { margin-right: 0; }
.act-icon { font-size: 52rpx; }
.act-title { display: block; font-size: 32rpx; font-weight: 650; margin: 8rpx 0 2rpx; color: var(--text); }
.act-desc { font-size: 24rpx; color: var(--text3); }

.recent-list { margin-top: 10rpx; }
.recent-item { display: flex; flex-direction: row; align-items: center; padding: 20rpx 16rpx; background: var(--surface); border-radius: 14rpx; margin-bottom: 10rpx; }
.r-icon { font-size: 48rpx; margin-right: 16rpx; }
.r-info { flex: 1; min-width: 0; }
.r-name { font-weight: 650; font-size: 32rpx; display: block; color: var(--text); }
.r-hint { font-size: 26rpx; color: var(--text3); }
.r-meta { font-family: var(--font-mono); font-size: 24rpx; color: var(--text3); min-width: 140rpx; text-align: right; }

.stats { margin-top: 20rpx; font-size: 24rpx; color: var(--text3); text-align: center; }

.auth-row { display: flex; align-items: center; gap: 24rpx; margin: 24rpx 0 8rpx; }
.prof-nickname-input { flex: 1; font-size: 28rpx; color: var(--text); background: var(--surface); border-radius: 12rpx; padding: 20rpx 24rpx; }
.auth-done-btn { margin-top: 20rpx; }
.auth-skip { text-align: center; margin-top: 20rpx; font-size: 28rpx; color: var(--text3); padding: 12rpx; }
.cache-area { text-align: center; margin-top: 28rpx; }
.cache-btn { background: transparent; color: var(--text3); font-size: 24rpx; padding: 8rpx 24rpx; border: none; opacity: 0.5; }

.modal-title { font-size: 40rpx; font-weight: 700; display: block; margin-bottom: 8rpx; color: var(--text); }
.modal-sub { font-size: 28rpx; color: var(--text3); display: block; margin-bottom: 20rpx; }
.modal-room-id { font-family: var(--font-mono); font-weight: 700; color: var(--text); }

.input-wrap { position: relative; margin-bottom: 24rpx; }
.input { width: 100%; box-sizing: border-box; }
.input-row { display: flex; flex-direction: row; align-items: center; margin-bottom: 28rpx; }
.input-flex { flex: 1; font-size: 34rpx; }
.rnd-btn { font-size: 36rpx; padding: 8rpx 8rpx 8rpx 16rpx; flex-shrink: 0; }
.room-input { text-align: center; font-size: 52rpx; font-family: var(--font-mono); letter-spacing: 16rpx; min-height: 100rpx; margin-bottom: 28rpx; }

.version-tag { text-align: center; font-size: 24rpx; color: var(--text3); margin-top: 8rpx; }
